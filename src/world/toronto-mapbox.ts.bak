/**
 * Mapbox GL JS 3D map for Agentropolis.
 * - Style: Mapbox Standard
 * - Camera: tilted, city-builder-like
 * - Driven by SimulationEngine state (CityState + day)
 */
import mapboxgl from "mapbox-gl";
import type { CityState } from "../types/city-state.js";

export interface TorontoMapboxOptions {
  container: HTMLElement;
}

type StateGetter = () => { state: Readonly<CityState>; day: number };

const TORONTO_CENTER: [number, number] = [-79.3832, 43.6532];

export class TorontoMapboxScene {
  private map: mapboxgl.Map | null = null;
  private animationId = 0;

  constructor(options: TorontoMapboxOptions) {
    const { container } = options;

    const env = (import.meta as any).env ?? {};
    const token: string = env.VITE_MAPBOX_ACCESS_TOKEN ?? "";
    if (!token) {
      container.innerHTML =
        '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:#9ca3af;font-family:system-ui;">Set VITE_MAPBOX_ACCESS_TOKEN in .env to see the map.</div>';
      return;
    }

    this.map = new mapboxgl.Map({
      container,
      accessToken: token,
      style: "mapbox://styles/mapbox/standard",
      center: TORONTO_CENTER,
      zoom: 14.5,
      pitch: 60,
      bearing: -20,
      antialias: true,
    });

    this.map.addControl(new mapboxgl.NavigationControl(), "bottom-right");
  }

  updateFromState(_state: Readonly<CityState>, day: number) {
    if (!this.map) return;
    const timeOfDay = (day % 24) / 24;

    // Mild camera drift over the day, city-builder style.
    const basePitch = 60;
    const pitchOffset = Math.cos(timeOfDay * Math.PI * 2) * 4;
    this.map.setPitch(basePitch + pitchOffset);

    const baseBearing = -20;
    const bearingOffset = Math.sin(timeOfDay * Math.PI * 2) * 6;
    this.map.setBearing(baseBearing + bearingOffset);
  }

  startRenderLoop(getState: StateGetter) {
    const tick = () => {
      this.animationId = requestAnimationFrame(tick);
      const { state, day } = getState();
      this.updateFromState(state, day);
    };
    tick();
  }

  dispose() {
    cancelAnimationFrame(this.animationId);
    if (this.map) {
      this.map.remove();
      this.map = null;
    }
  }
}

